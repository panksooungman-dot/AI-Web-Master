#!/bin/sh
# PROJECT_STATUS.md SSOT auto-sync + freshness guard.
#
# PROJECT_STATUS.md declares itself this repo's Single Source of Truth and its own
# "Working Rules" section says step 5 of every task is "PROJECT_STATUS.md 업데이트" before
# committing. This hook enforces that automatically:
#
#   git commit
#     -> this hook inspects the STAGED diff itself
#     -> if it touches apps/** or packages/**, delegates to
#        .githooks/lib/sync-project-status.mjs
#     -> that script asks an AI provider (.githooks/lib/ai-provider.mjs) to
#        produce a JSON patch for only the sections that actually changed
#        (never a full-file rewrite), splices it into PROJECT_STATUS.md,
#        and `git add`s the result
#     -> commit proceeds
#
# The decision of WHETHER to touch PROJECT_STATUS.md at all (docs-only commits,
# README-only commits, etc.) is made here / in sync-project-status.mjs by
# inspecting staged paths — never by the AI. Once invoked, the AI's only job is
# "how should the whitelisted sections read now", returned as JSON.
#
# Idempotency: sync-project-status.mjs caches a hash of the last-synced diff
# under .git/.ssot-cache/ (never inside PROJECT_STATUS.md itself) so retrying
# an identical staged commit doesn't re-call the AI.
#
# Any failure (AI provider unreachable, timeout, malformed response, patch
# validation failure) aborts the commit with a clear message on stderr.
#
# Bypass (intentional, e.g. a docs-only or hotfix commit): git commit --no-verify

staged_files=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$staged_files" ]; then
  exit 0
fi

node .githooks/lib/sync-project-status.mjs
exit $?
