# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next/
out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local workspace registry (machine-specific paths) / local contact submission log
/lib/data/
apps/cnbiz-web/lib/data/

# Website Builder dashboard output (generated Next.js projects, not repo source)
/.generated-websites/

# AI Business OS CLI runtime cache/state/logs (agent memory, history, execution logs —
# regenerated on demand, not persistent data)
/.runtime/

# Playwright MCP QA artifacts (screenshots, snapshots, console logs)
/.playwright-mcp/

# AI Business OS CLI
packages/cli/dist/