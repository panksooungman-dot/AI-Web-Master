# Auth data store (Supabase, server-side only — NOT NEXT_PUBLIC_*).
# Required in production (Vercel): lib/db/index.ts's getDefaultStore() fails fast with
# "[Production misconfig] ..." (surfaced as 400 by /api/auth/login) when either is missing
# and NODE_ENV=production. Locally (next dev), missing values fall back to a fs-backed store,
# so these can stay empty for local development.
# NOTE: distinct from NEXT_PUBLIC_SUPABASE_URL/NEXT_PUBLIC_SUPABASE_ANON_KEY used by the
# unrelated root-level lib/supabase.ts (v1 legacy site) — this app needs the service role key,
# not the anon key.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Email notifications for the cnbiz.ai.kr chatbot inquiry pipeline (lib/inquiries/notify.ts).
# Originally built for the public Contact form (now removed — CNBIZ.KR no longer takes website
# requests directly), lib/contact/email/* was kept as-is and reused here rather than duplicated.
# Leave CONTACT_EMAIL_PROVIDER unset (or set to a value with no matching case) to skip email
# sending — inquiries are still saved to the registry either way.

# Provider to use. Supported: "resend". Add a new case in lib/contact/email/index.ts
# and a provider file under lib/contact/email/providers/ to support another one.
CONTACT_EMAIL_PROVIDER=resend

# Notification recipient/sender
CONTACT_EMAIL_TO=
CONTACT_EMAIL_FROM=

# Resend (used when CONTACT_EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# Google Analytics 4 (optional). Only loaded in production (NODE_ENV=production) and only when
# set — see app/layout.tsx. Leave empty locally/in preview to skip loading gtag.js entirely.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Figma Import/Export — Design Automation Phase 7 (optional). Without it, lib/design/figma-generator.ts
# falls back to deterministic simulated content instead of calling the real Figma REST API.
FIGMA_API_TOKEN=

# AI Provider keys — power every real (non-fallback) AI call in this app: AI Analysis Engine
# (lib/ai-analysis), Design Automation Phase 1-9 (lib/design/*-generator.ts), and Website Builder
# content generation (packages/cli/src/website/content.ts, invoked by lib/aiJobs/executor.ts).
# None of these are called directly — this app shells out to `packages/cli` as a child process
# (lib/ai/bridge.ts's chatViaCli(), lib/aiJobs/executor.ts), which inherits this process's env vars
# and resolves them via packages/cli/src/providers/manager.ts's .runtime/config/providers.json
# template (`"apiKey": "${ANTHROPIC_API_KEY}"` etc. — the literal env var name, substituted at
# call time, never written to disk as a real secret).
#
# If NONE of these are set, every call above falls back to its existing deterministic content
# (buildDefaultWireframe(), buildDefaultJudgment(), etc.) — this is documented, expected behavior,
# not an error. Set at least one to enable real AI responses; see PROJECT_STATUS.md for the current
# connection status of this environment.
#
# Default provider is "anthropic" (packages/cli/src/providers/manager.ts's DEFAULT_CONFIG) unless
# changed via `ai provider set-default <id>` (writes to .runtime/config/providers.json, not env-based).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional — overrides the model name shown on /developer/ai's Provider Status card
# (lib/providers/status.ts); does not affect which model is actually called.
OPENAI_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
OPENROUTER_API_KEY=

# Local Ollama endpoint (optional, no API key required). Defaults to http://localhost:11434
# (see lib/providers/status.ts, packages/cli/src/providers/ollama.ts) — only set this if Ollama
# runs somewhere else. Note: a local Ollama instance is unreachable from Vercel's serverless
# production environment — this is only useful for local development.
OLLAMA_HOST=

# AI 홈페이지 무료 제작 CTA(Header/Footer/Hero/CTASection 등)와 /contact·/request redirect가
# 이동할 대상. 비워두면 https://cnbiz.ai.kr로 폴백한다 (lib/links.ts).
NEXT_PUBLIC_CNBIZ_AI_URL=

# cnbiz.ai.kr 프로젝트 AI 챗봇이 POST /api/external/inquiries를 서버-투-서버로 호출할 때 보내는
# x-api-key 헤더 값 (lib/auth/apiKey.ts). 세션 쿠키를 쓸 수 없는 외부 호출의 유일한 인증 수단이므로
# 프로덕션에서는 필수 — 값이 없으면 verifyExternalApiKey()가 프로덕션에서 모든 요청을 거부한다.
# 로컬 개발(next dev)에서는 비워두면 경고만 남기고 통과시킨다.
CHATBOT_API_KEY=
