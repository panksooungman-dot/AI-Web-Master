{
  "name": "@ai-business-os/cli",
  "version": "1.1.0",
  "description": "AI Business OS CLI",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "ai": "./bin/ai.js"
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'); fs.rmSync('dist/config',{recursive:true,force:true}); fs.rmSync('dist/templates',{recursive:true,force:true}); fs.cpSync('src/config','dist/config',{recursive:true}); fs.cpSync('src/templates','dist/templates',{recursive:true})\"",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@cnbiz/design-system": "*",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fs-extra": "^11.3.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3",
    "tsx": "^4.19.4",
    "rimraf": "^6.0.1"
  }
}