# Public site URL used for metadata, sitemap.xml, robots.txt, and Open Graph tags.
# Set this once you know the production domain — until then, a generated placeholder is used.
NEXT_PUBLIC_SITE_URL=https://example.com

# Optional — connect a transactional email provider to actually deliver messages
# submitted through the contact form (app/api/contact/route.ts) and newsletter
# signup (app/api/newsletter/route.ts). Both routes work without these; they log
# submissions to the server console until an email provider is wired in.
# CONTACT_EMAIL_TO=
# CONTACT_EMAIL_FROM=
# RESEND_API_KEY=
